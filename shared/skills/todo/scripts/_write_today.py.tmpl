#!/usr/bin/env python3
"""
_write_today.py — atomic-append helper for the todo skill.

Appends a new Todo to the correct per-day file under
`<agent_workdir>/todo_list/<YYYYMM>/<DD>.json`. Uses the write-to-tempfile
+ os.replace pattern so concurrent writers (the agent's Edit/Write, the
web-ui's POST /api/todos/write) do not corrupt the file.

This is an INTERNAL utility — agents that are planning their own work
should prefer direct Edit/Write on the day file. This helper exists for
scripts and for the pre-heartbeat hook.

Concept-name substitution point: the concept is "Todo". If the product
name changes, only this comment and the SKILL.md.tmpl need to track it;
the JSON field names do not encode the concept name.
"""

from __future__ import annotations

import argparse
import json
import os
import sys
from datetime import date as _date, datetime
from pathlib import Path


def _parse_date(value: str | None) -> _date:
    if value is None:
        return datetime.now().date()
    try:
        return datetime.strptime(value, "%Y-%m-%d").date()
    except ValueError as exc:
        raise SystemExit(f"--date must be YYYY-MM-DD: {exc}") from exc


def _day_file(agent_workdir: Path, day: _date) -> Path:
    return agent_workdir / "todo_list" / day.strftime("%Y%m") / f"{day.strftime('%d')}.json"


def _load_list(path: Path) -> list[dict]:
    if not path.exists():
        return []
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise SystemExit(f"todo file at {path} is not valid JSON: {exc}") from exc
    if not isinstance(data, list):
        raise SystemExit(f"todo file at {path} must hold a JSON list; got {type(data).__name__}")
    return data


def _next_todo_id(todos: list[dict]) -> str:
    max_n = 0
    for item in todos:
        tid = item.get("id", "")
        if isinstance(tid, str) and tid.startswith("t") and tid[1:].isdigit():
            max_n = max(max_n, int(tid[1:]))
    return f"t{max_n + 1}"


def _atomic_write(path: Path, payload: list[dict]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + f".tmp.{os.getpid()}")
    tmp.write_text(
        json.dumps(payload, indent=2, ensure_ascii=False) + "\n",
        encoding="utf-8",
    )
    os.replace(tmp, path)


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="Append a Todo to the correct day file (atomic).")
    parser.add_argument("--title", required=True, help="Todo title.")
    parser.add_argument("--description", default="", help="Free-form description (may be empty).")
    parser.add_argument("--date", default=None, help="Target day as YYYY-MM-DD; defaults to today.")
    parser.add_argument(
        "--agent-workdir",
        default=None,
        help="Agent workdir that owns todo_list/; defaults to the current working directory.",
    )
    args = parser.parse_args(argv)

    agent_workdir = Path(args.agent_workdir).resolve() if args.agent_workdir else Path.cwd().resolve()
    day = _parse_date(args.date)
    path = _day_file(agent_workdir, day)

    todos = _load_list(path)
    new_id = _next_todo_id(todos)
    todos.append(
        {
            "id": new_id,
            "title": args.title,
            "description": args.description,
            "subtasks": [],
            "done": False,
        }
    )
    _atomic_write(path, todos)

    print(new_id)
    return 0


if __name__ == "__main__":
    sys.exit(main())
