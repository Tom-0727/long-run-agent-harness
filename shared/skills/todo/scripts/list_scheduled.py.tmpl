#!/usr/bin/env python3
"""
list_scheduled.py — print the Scheduled Task list from scheduled_tasks.json.

Concept substitution point: "Scheduled Task". Rename mechanically if renamed upstream.

Missing file prints `[]`. Output is always pretty-printed JSON (two-space
indent), ensure_ascii=False so Chinese titles read naturally.
"""

from __future__ import annotations

import argparse
import importlib.util
import json
import sys
from importlib.machinery import SourceFileLoader
from pathlib import Path

_HERE = Path(__file__).resolve().parent


def _load_common():
    for candidate in (_HERE / "_common.py", _HERE / "_common.py.tmpl"):
        if candidate.exists():
            loader = SourceFileLoader("_todo_common", str(candidate))
            spec = importlib.util.spec_from_loader(loader.name, loader)
            if spec is None:
                continue
            mod = importlib.util.module_from_spec(spec)
            loader.exec_module(mod)
            return mod
    raise SystemExit(f"_common.py(.tmpl) not found in {_HERE}")


_common = _load_common()
load_list_json = _common.load_list_json


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(description="Print the Scheduled Task list as JSON.")
    parser.add_argument("--agent-workdir", default=None)
    args = parser.parse_args(argv)

    agent_workdir = (
        Path(args.agent_workdir).resolve() if args.agent_workdir else Path.cwd().resolve()
    )
    store_path = agent_workdir / "scheduled_tasks.json"
    items = load_list_json(store_path)
    print(json.dumps(items, indent=2, ensure_ascii=False))
    return 0


if __name__ == "__main__":
    sys.exit(main())
