#!/usr/bin/env python3
"""Read mailbox messages for agent consumption, supporting per-contact reading."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path


def resolve_agent_dir() -> Path:
    script_path = Path(__file__).resolve()
    for parent in script_path.parents:
        if (parent / "mailbox" / "contacts.json").exists() and (parent / "mailbox_io.py").exists():
            return parent
    raise SystemExit("unable to locate agent workspace root from script path")


AGENT_DIR = resolve_agent_dir()
sys.path.insert(0, str(AGENT_DIR))

from mailbox_io import (
    count_unread,
    load_contacts,
    messages_after_id,
    read_messages,
)


def load_last_read_id(contact: str) -> str | None:
    state_path = AGENT_DIR / "Runtime" / "mailbox_read_last_id" / contact
    if not state_path.exists():
        return None
    value = state_path.read_text(encoding="utf-8").strip()
    return value or None


def save_last_read_id(contact: str, mailbox_id: str) -> None:
    state_dir = AGENT_DIR / "Runtime" / "mailbox_read_last_id"
    state_dir.mkdir(parents=True, exist_ok=True)
    (state_dir / contact).write_text(f"{mailbox_id}\n", encoding="utf-8")


def contact_key(contact_name: str) -> str:
    return contact_name if contact_name == "human" else f"agent.{contact_name}"


def do_summary(contacts: dict) -> None:
    result = []
    for name, info in contacts.items():
        key = contact_key(name)
        mailbox_path = AGENT_DIR / "mailbox" / info["mailbox_file"]
        last_id = load_last_read_id(key)
        n = count_unread(mailbox_path, last_id)
        if n > 0:
            result.append({"contact": name, "unread": n})
    print(json.dumps(result, ensure_ascii=False))


def do_read(contact_name: str, contact_info: dict, count: int | None) -> None:
    key = contact_key(contact_name)
    mailbox_path = AGENT_DIR / "mailbox" / contact_info["mailbox_file"]

    if count is not None:
        all_msgs = read_messages(mailbox_path)
        output = all_msgs[-count:]
    else:
        last_read_id = load_last_read_id(key)
        output = messages_after_id(mailbox_path, last_read_id)

    if output:
        last_id = output[-1].get("id")
        if isinstance(last_id, str) and last_id:
            save_last_read_id(key, last_id)

    print(json.dumps(output, ensure_ascii=False))


def main() -> None:
    parser = argparse.ArgumentParser(
        description=(
            "Read mailbox messages. Without --from, reads human messages. "
            "With --summary, shows unread counts per contact."
        )
    )
    parser.add_argument(
        "--from",
        dest="from_contact",
        default="human",
        help="Contact to read messages from (default: human)",
    )
    parser.add_argument(
        "--summary",
        action="store_true",
        help="Show unread message counts per contact",
    )
    parser.add_argument(
        "count",
        nargs="?",
        type=int,
        help="Optional: return latest N messages instead of unread",
    )
    args = parser.parse_args()

    if args.count is not None and args.count <= 0:
        raise SystemExit("count must be a positive integer")

    contacts = load_contacts(AGENT_DIR / "mailbox" / "contacts.json")

    if args.summary:
        do_summary(contacts)
        return

    if args.from_contact not in contacts:
        raise SystemExit(f"contact '{args.from_contact}' not found in contacts.json")

    do_read(args.from_contact, contacts[args.from_contact], args.count)


if __name__ == "__main__":
    main()
